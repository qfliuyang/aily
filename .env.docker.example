# Copy to .env.docker for pre-production use. Do not commit .env.docker.

AILY_HOST_PORT=8000
AILY_DOCKER_IMAGE=aily:preprod
AILY_DOCKER_DATA_DIR=./.docker-data/data
AILY_DOCKER_VAULT_DIR=./.docker-data/vault
AILY_DOCKER_CHAOS_DIR=./.docker-data/chaos

AILY_DOCKER_HOSTED_MODE=true
AILY_DOCKER_UI_AUTH_ENABLED=true
AILY_DOCKER_UI_AUTH_TOKEN=replace-with-a-long-random-token
AILY_DOCKER_UI_RATE_LIMIT_REQUESTS=200
AILY_DOCKER_UI_RATE_LIMIT_WINDOW_SECONDS=60

# Keep these false for the fast Docker preprod smoke gate.
# Set to true for an explicit real-LLM Docker acceptance run.
AILY_DOCKER_DIKIWI_ENABLED=false
AILY_DOCKER_INNOVATION_ENABLED=false
AILY_DOCKER_ENTREPRENEUR_ENABLED=false
AILY_DOCKER_MAC_ENABLED=false

AILY_DOCKER_LLM_PROVIDER=kimi
AILY_DOCKER_LLM_API_KEY=
AILY_DOCKER_KIMI_API_KEY=
AILY_DOCKER_DEEPSEEK_API_KEY=
AILY_DOCKER_LLM_TIMEOUT_SECONDS=120
AILY_DOCKER_LLM_MAX_RETRIES=0
AILY_DOCKER_MAX_FILE_SIZE=52428800
