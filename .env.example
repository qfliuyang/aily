# Aily local/deployment configuration example.
# Copy to .env and replace placeholders with real values. Do not commit .env.

# Runtime paths
AILY_DATA_DIR=~/.aily
OBSIDIAN_VAULT_PATH=~/Documents/aily/vault
DIKIWI_VAULT_PATH=~/Documents/aily/vault
OBSIDIAN_REST_API_PORT=27123

# Studio/private deployment security
HOSTED_MODE=false
UI_AUTH_ENABLED=false
UI_AUTH_TOKEN=<generate-a-long-random-token-when-auth-is-enabled>
TRUSTED_PROXY_HEADERS=false

# DIKIWI processing controls
AILY_DIKIWI_ENABLED=true
AILY_INNOVATION_ENABLED=true
AILY_ENTREPRENEUR_ENABLED=true
AILY_MAC_ENABLED=true

# LLM provider. Kimi is the default; set one real key before enabling real DIKIWI.
LLM_PROVIDER=kimi
LLM_BASE_URL=https://api.moonshot.cn/v1
LLM_MODEL=kimi-k2.6
LLM_API_KEY=
KIMI_API_KEY=
MOONSHOT_API_KEY=
DEEPSEEK_API_KEY=
ZHIPU_API_KEY=

# Feishu integration (optional)
FEISHU_APP_ID=
FEISHU_APP_SECRET=
FEISHU_VERIFICATION_TOKEN=
FEISHU_ENCRYPT_KEY=
AILY_DIGEST_FEISHU_OPEN_ID=

# Search/browser integrations (optional)
TAVILY_API_KEY=
TAVILY_SEARCH_DEPTH=basic
BROWSER_USE_API_KEY=

# Upload/source-worker limits
MAX_FILE_SIZE=52428800
MAX_IMAGE_SIZE=10485760
UI_MAX_UPLOAD_FILES=8
UI_MAX_ACTIVE_UPLOADS=16
UI_UPLOAD_CONCURRENCY=2
SOURCE_WORKER_COUNT=1
SOURCE_JOB_MAX_PENDING=500
SOURCE_MAX_RETRY_ATTEMPTS=5
SOURCE_RETRY_BASE_DELAY_SECONDS=300
SOURCE_RETRY_MAX_DELAY_SECONDS=3600
SOURCE_JOB_STALE_LOCK_SECONDS=1800
FOLLOW_EXTERNAL_LINKS_FOR_UPLOADS=false
URL_INTAKE_ALLOW_PRIVATE_NETWORK=false
